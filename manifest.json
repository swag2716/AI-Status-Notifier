{
  "manifest_version": 3,
  "name": "AI Status Notifier",
  "version": "3.0.0",
  "description": "Get notified when an AI tool finishes responding — even from another tab.",
  "permissions": ["notifications", "scripting", "tabs", "storage", "alarms"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Status Notifier",
    "default_icon": {
      "16": "icons/idle16.png",
      "48": "icons/idle48.png",
      "128": "icons/idle128.png"
    }
  },
  "icons": {
    "16": "icons/idle16.png",
    "48": "icons/idle48.png",
    "128": "icons/idle128.png"
  }
}
